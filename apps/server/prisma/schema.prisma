datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum DrawingStatus {
  UPLOADED
  OCR_PROCESSING
  OCR_COMPLETED
  OCR_FAILED
  PARSING
  PARSED
  FAILED
}

enum Discipline {
  ARCHITECTURAL
  STRUCTURAL
  MECHANICAL
  ELECTRICAL
  PLUMBING
  FIRE
  INTERIOR
  UNKNOWN
}

enum RfiStatus {
  GENERATED
  REVIEWED
  SENT
}

model Drawing {
  id         String         @id @default(uuid()) @db.Uuid
  hash       String         @unique @db.VarChar(64)
  fileName   String?        @map("file_name") @db.VarChar
  fileUrl    String?        @map("file_url") @db.Text
  publicId   String?        @map("public_id") @db.VarChar
  discipline Discipline?
  status     DrawingStatus?
  parsedJson               Json?          @map("parsed_json")
  ocrOutput                String?        @map("ocr_output") @db.Text
  documentType             String?        @map("document_type") @db.VarChar
  classificationConfidence Float?         @map("classification_confidence")
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamp

  conflicts  Conflict[]
  rfis       Rfi[]

  @@map("drawings")
}

enum ConflictCategory {
  SEMANTIC
  GEOMETRY
  DISCIPLINE
}

enum ConflictSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Conflict {
  id             String           @id @default(uuid()) @db.Uuid
  drawingId      String           @map("drawing_id") @db.Uuid
  category       ConflictCategory
  severity       ConflictSeverity
  title          String           @db.VarChar
  description    String           @db.Text
  entityA        String           @db.VarChar
  entityB        String?          @db.VarChar
  recommendation String           @db.Text
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamp

  drawing        Drawing          @relation(fields: [drawingId], references: [id])
  rfis           Rfi[]

  @@map("conflicts")
}

model Rfi {
  id             String           @id @default(uuid()) @db.Uuid
  drawingId      String           @map("drawing_id") @db.Uuid
  conflictId     String           @map("conflict_id") @db.Uuid
  title          String           @db.VarChar
  priority       String           @db.VarChar
  discipline     String           @db.VarChar
  subject        String           @db.VarChar
  description    String           @db.Text
  question       String           @db.Text
  recommendation String           @db.Text
  status         String           @db.VarChar
  conflictHash   String           @map("conflict_hash") @db.VarChar(64)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamp

  drawing        Drawing          @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  conflict       Conflict         @relation(fields: [conflictId], references: [id], onDelete: Cascade)

  @@index([drawingId])
  @@map("rfis")
}
